# =============================================================================
# Finance Pro — Frontend Environment Variables
# =============================================================================
# Copy this file and rename it to .env.local for local development.
# On Render (or any CI/CD platform), set these as environment variables
# in the service dashboard — do NOT commit real values to the repo.
#
# Vite env variable rules:
#   - Must be prefixed with VITE_ to be exposed to the browser bundle.
#   - Available at runtime via: import.meta.env.VITE_*
#   - Values are baked in at BUILD TIME — not runtime.
# =============================================================================

# ---------------------------------------------------------------------------
# VITE_API_URL  (Required)
# ---------------------------------------------------------------------------
# The base URL of the FastAPI backend including the /api prefix.
#
# Local development:
#   VITE_API_URL=http://localhost:8000/api
#
# Render deployment (replace with your actual Render backend URL):
#   VITE_API_URL=https://finance-pro-backend.onrender.com/api
#
# If this variable is not set, the frontend falls back to localhost:8000/api
# which means it will only work on a local machine.
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
