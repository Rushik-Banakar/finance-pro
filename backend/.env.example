# =============================================================================
# Finance Pro — Backend Environment Variables
# =============================================================================
# Copy this file and rename it to .env for local development.
# On Render, set these as environment variables in the service dashboard.
# NEVER commit your real .env file — it is already git-ignored.
# =============================================================================

# ---------------------------------------------------------------------------
# DATABASE_URL  (Required for production)
# ---------------------------------------------------------------------------
# Local development (SQLite — zero setup, but data lost on Render redeploy):
#   DATABASE_URL=sqlite:///./money_manager.db
#
# Render PostgreSQL (recommended for production — no data loss on redeploy):
#   DATABASE_URL=postgresql://user:password@host:5432/finance_pro
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./money_manager.db

# ---------------------------------------------------------------------------
# SECRET_KEY  (REQUIRED — app will not start without this)
# ---------------------------------------------------------------------------
# Used to sign and verify all JWT access tokens.
# There is NO hardcoded fallback. The app will refuse to start if this is:
#   - missing or blank
#   - set to the placeholder value below
#   - shorter than 32 characters
#
# Generate a unique secure value for each environment:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Local dev:  add the generated value to your .env file
# Render:     add it in the service dashboard → Environment Variables
#
# WARNING: Never share this value or commit it to version control.
#          If it leaks, all existing user sessions must be invalidated
#          by rotating to a new value and redeploying.
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32


# ---------------------------------------------------------------------------
# CORS_ORIGINS  (Required for production)
# ---------------------------------------------------------------------------
# Controls which frontend URLs the browser will trust when making API calls.
# The localhost dev origins are always included automatically — you only need
# to add your deployed frontend URL(s) here.
#
# Accepts two formats — use whichever is easiest in your dashboard:
#
#   Format 1 — JSON array (quote-safe for most dashboards):
#     CORS_ORIGINS=["https://finance-pro.onrender.com"]
#
#   Format 2 — Comma-separated (easier to type, no quotes needed):
#     CORS_ORIGINS=https://finance-pro.onrender.com,https://finance-pro.vercel.app
#
# Local development: leave this unset — localhost is always allowed by default.
# Render/Vercel deployment: set to your deployed frontend URL (no trailing slash).
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://your-frontend-url.onrender.com

# ---------------------------------------------------------------------------
# LLM API Keys  (At least one required for AI Coach features)
# ---------------------------------------------------------------------------
# The app tries providers in this order: Groq → OpenAI → Gemini → Anthropic.
# If none are set, the AI Coach returns a static local fallback response.
# Get a free Groq key at: https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
